PORT=5000
NODE_ENV=development
# MongoDB Connection String (e.g. mongodb+srv://<username>:<password>@<cluster-url>/mutual_fund_kyc)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/mutual_fund_kyc?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_strong_secret
JWT_EXPIRES_IN=1d
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_BUCKET=kyc-documents
CORS_ORIGIN=http://localhost:3000
